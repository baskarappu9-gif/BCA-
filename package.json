{
  "name": "pricewatch-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install --prefix pricewatch/frontend && npm install --prefix pricewatch/backend",
    "dev:frontend": "npm run dev --prefix pricewatch/frontend",
    "dev:backend": "npm run dev --prefix pricewatch/backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}